{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "username": { "type": "string" },
        "onboarded": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "username"]
    },
    "Portfolio": {
      "title": "Portfolio",
      "description": "Real estate professional portfolio data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "profilePhoto": { "type": "string" },
        "fullName": { "type": "string" },
        "jobTitle": { "type": "string" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "socials": {
          "type": "object",
          "properties": {
            "instagram": { "type": "string" },
            "linkedin": { "type": "string" },
            "twitter": { "type": "string" },
            "website": { "type": "string" }
          }
        },
        "customLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "featuredProjects": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "location": { "type": "string" },
              "image": { "type": "string" },
              "tags": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "fullName"]
    },
    "Username": {
      "title": "Username",
      "description": "Mapping of username to user ID",
      "type": "object",
      "properties": {
        "uid": { "type": "string" }
      },
      "required": ["uid"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User documents"
    },
    "/portfolios/{uid}": {
      "schema": "Portfolio",
      "description": "Portfolio documents"
    },
    "/usernames/{username}": {
      "schema": "Username",
      "description": "Username to UID mapping"
    }
  }
}
